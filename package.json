{
  "name": "americas",
  "type": "module",
  "packageManager": "yarn@4.14.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "yarn node src/index.ts",
    "create-round": "yarn node src/create-round.ts",
    "submit-round": "yarn node src/submit-round.ts",
    "end-round": "yarn node src/end-round.ts",
    "send-reminders": "yarn node src/send-reminders.ts",
    "list-countries": "yarn node src/list-countries.ts",
    "typecheck": "tsc --noEmit",
    "test": "yarn node --test --import ./tests/setup.ts 'tests/**/*.test.ts'",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "prepare": "husky",
    "build-kml": "ogrmerge.py -dsco NameField=player -o rounds.kml -f kml rounds/*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@tsconfig/node24": "24.0.4",
    "@types/geojson": "7946.0.16",
    "@types/node": "24.12.3",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@js-joda/core": "6.0.1",
    "@js-joda/timezone": "2.25.1",
    "@ngageoint/geopackage": "4.2.6",
    "@turf/boolean-point-in-polygon": "7.3.5",
    "@turf/distance": "7.3.5",
    "geographiclib-dms": "2.2.0"
  },
  "resolutions": {
    "better-sqlite3": "12.9.0"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  }
}
